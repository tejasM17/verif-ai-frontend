{
  "info": {
    "name": "VERIF-AI API",
    "description": "Complete API collection for VERIF-AI backend testing",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "System",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/health",
              "host": ["{{base_url}}"],
              "path": ["health"]
            }
          }
        },
        {
          "name": "Root / Docs",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/",
              "host": ["{{base_url}}"],
              "path": [""]
            }
          }
        }
      ]
    },
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"student@university.edu\",\n  \"password\": \"TestPassword123!\",\n  \"role\": \"student\",\n  \"display_name\": \"John Doe\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/register",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "register"]
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"student@university.edu\",\n  \"password\": \"TestPassword123!\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "login"]
            }
          }
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{firebase_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/auth/me",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "me"]
            }
          }
        },
        {
          "name": "Auth Health",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/auth/health",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "health"]
            }
          }
        }
      ]
    },
    {
      "name": "Documents",
      "item": [
        {
          "name": "Check Readiness",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{firebase_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/documents/readiness",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "documents", "readiness"]
            }
          }
        },
        {
          "name": "List My Documents",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{firebase_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/documents/my",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "documents", "my"]
            }
          }
        },
        {
          "name": "Submit GitHub URL",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{firebase_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"github_url\": \"https://github.com/username\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/documents/github",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "documents", "github"]
            }
          }
        }
      ]
    },
    {
      "name": "Analysis",
      "item": [
        {
          "name": "Start Analysis",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{firebase_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"student_uid\": \"{{user_id}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/analysis/start",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "analysis", "start"]
            }
          }
        },
        {
          "name": "Get Analysis Result",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{firebase_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/analysis/result/{{user_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "analysis", "result", "{{user_id}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Profile",
      "item": [
        {
          "name": "Get Public Profile",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/profile/{{user_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "profile", "{{user_id}}"]
            }
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{firebase_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"skills\": [\"React\", \"TypeScript\", \"Python\"],\n  \"domain\": \"Software Engineering\",\n  \"location\": \"San Francisco, CA\",\n  \"bio\": \"Full-stack engineer with passion for AI\",\n  \"is_public\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/profile/update",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "profile", "update"]
            }
          }
        }
      ]
    },
    {
      "name": "Discovery",
      "item": [
        {
          "name": "Search Students",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{firebase_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/discover/search?skills=React&min_trust=70&limit=20&offset=0",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "discover", "search"],
              "query": [
                {
                  "key": "skills",
                  "value": "React"
                },
                {
                  "key": "min_trust",
                  "value": "70"
                },
                {
                  "key": "limit",
                  "value": "20"
                },
                {
                  "key": "offset",
                  "value": "0"
                }
              ]
            }
          }
        },
        {
          "name": "Shortlist Student",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{firebase_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/discover/shortlist/{{student_uid}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "discover", "shortlist", "{{student_uid}}"]
            }
          }
        },
        {
          "name": "Get Shortlist",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{firebase_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/discover/shortlist?limit=20&offset=0",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "discover", "shortlist"],
              "query": [
                {
                  "key": "limit",
                  "value": "20"
                },
                {
                  "key": "offset",
                  "value": "0"
                }
              ]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000"
    },
    {
      "key": "firebase_token",
      "value": ""
    },
    {
      "key": "user_id",
      "value": ""
    },
    {
      "key": "student_uid",
      "value": ""
    }
  ]
}
